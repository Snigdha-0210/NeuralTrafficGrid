# Neural Traffic Grid Environment Variables
# Create a copy of this file named .env.local and fill in the values for local development.
# For Vercel deployment, add these directly in the Vercel Dashboard under "Environment Variables".

# The URL of the FastAPI Backend
NEXT_PUBLIC_API_URL=https://ntg-backend.onrender.com/api

# Note: This project relies completely on local AI/ML models (PyTorch, scikit-fuzzy)
# and synthetic data, so no external third-party API keys (like OpenAI) are needed!
